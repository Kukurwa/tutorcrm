# App
NEXT_PUBLIC_APP_NAME=TutorCRM
NEXT_PUBLIC_DEFAULT_LOCALE=ru
NEXT_PUBLIC_DEFAULT_TZ=Europe/Kyiv
NODE_ENV=development

# Auth (FE-0: заглушка; FE-1 подключит NextAuth credentials + JWT)
NEXTAUTH_SECRET=dev-secret-change-me-please-32b
NEXTAUTH_URL=http://localhost:3000

# Mocks (FE-0)
MOCK_ENABLED=true
MOCK_LATENCY_MS=0
MOCK_ERROR_RATE=0

# Logging
LOG_LEVEL=info
